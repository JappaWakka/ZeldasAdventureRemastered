	else if AudioPosition >= 5.918 and AudioPosition <= 8.380 {return Localize.Subtitles.Dialogue.ForestOfTorian.Waldensop.GoodMorn.Line04}
	else if AudioPosition >= 8.405 and AudioPosition <= 9.540 {return Localize.Subtitles.Dialogue.ForestOfTorian.Waldensop.GoodMorn.Line05}
	else if AudioPosition >= 9.927 and AudioPosition <= 12.019 {return Localize.Subtitles.Dialogue.ForestOfTorian.Waldensop.GoodMorn.Line06}
	else if AudioPosition >= 12.147 and AudioPosition <= 14.340 {return Localize.Subtitles.Dialogue.ForestOfTorian.Waldensop.GoodMorn.Line07}
	else if AudioPosition >= 14.365 and AudioPosition <= 16.407 {return Localize.Subtitles.Dialogue.ForestOfTorian.Waldensop.GoodMorn.Line08}
	else return ""
}

